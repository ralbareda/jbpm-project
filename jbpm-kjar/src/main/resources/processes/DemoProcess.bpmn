<?xml version="1.0" encoding="UTF-8"?>
<bpmn2:definitions
    xmlns:bpmn2="http://www.omg.org/spec/BPMN/20100524/MODEL"
    xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
    xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
    xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:drools="http://www.jboss.org/drools"
    xsi:schemaLocation="
        http://www.omg.org/spec/BPMN/20100524/MODEL
        http://www.omg.org/spec/BPMN/20100524/MODEL/BPMN20.xsd"
    id="Definitions"
    targetNamespace="http://www.example.org/demo">

  <bpmn2:process id="demo.process" name="Demo Process" isExecutable="true">

    <bpmn2:property id="name"/>
    <bpmn2:property id="age"/>
    <bpmn2:property id="resultMessage"/>
    <bpmn2:property id="isAdult"/>

    <bpmn2:startEvent id="start"/>

    <bpmn2:scriptTask id="script1" name="Print Params" scriptFormat="java">
      <bpmn2:script>
        System.out.println(">>> BPMN received name = " + kcontext.getVariable("name"));
        System.out.println(">>> BPMN received age = " + kcontext.getVariable("age"));
      </bpmn2:script>
    </bpmn2:scriptTask>

    <bpmn2:exclusiveGateway id="gateway1" gatewayDirection="Diverging"/>

    <bpmn2:scriptTask id="underageTask" name="Underage Handling" scriptFormat="java">
      <bpmn2:script>
        System.out.println(">>> Underage branch executed");
      </bpmn2:script>
    </bpmn2:scriptTask>

    <bpmn2:scriptTask id="adultTask" name="Adult Handling" scriptFormat="java">
      <bpmn2:script>
        System.out.println(">>> Adult branch executed");
      </bpmn2:script>
    </bpmn2:scriptTask>

    <bpmn2:exclusiveGateway id="gateway2" gatewayDirection="Converging"/>

    <bpmn2:callActivity
        id="callSimpleRuleProcess"
        name="Call Simple Rule Subprocess"
        calledElement="simple.rule.process"
        drools:independent="false"
        drools:waitForCompletion="true">

      <bpmn2:ioSpecification>
          <bpmn2:dataInput id="in_age" name="age"/>
          <bpmn2:dataOutput id="out_isAdult" name="isAdult"/>
          <bpmn2:dataOutput id="out_message" name="resultMessage"/>

          <bpmn2:inputSet>
              <bpmn2:dataInputRefs>in_age</bpmn2:dataInputRefs>
          </bpmn2:inputSet>

          <bpmn2:outputSet>
              <bpmn2:dataOutputRefs>out_isAdult</bpmn2:dataOutputRefs>
              <bpmn2:dataOutputRefs>out_message</bpmn2:dataOutputRefs>
          </bpmn2:outputSet>
      </bpmn2:ioSpecification>

      <bpmn2:dataInputAssociation>
        <bpmn2:sourceRef>age</bpmn2:sourceRef>
        <bpmn2:targetRef>in_age</bpmn2:targetRef>
      </bpmn2:dataInputAssociation>

      <bpmn2:dataOutputAssociation>
          <bpmn2:sourceRef>out_isAdult</bpmn2:sourceRef>
          <bpmn2:targetRef>isAdult</bpmn2:targetRef>
      </bpmn2:dataOutputAssociation>

      <bpmn2:dataOutputAssociation>
        <bpmn2:sourceRef>out_message</bpmn2:sourceRef>
        <bpmn2:targetRef>resultMessage</bpmn2:targetRef>
      </bpmn2:dataOutputAssociation>

    </bpmn2:callActivity>

    <bpmn2:scriptTask id="printIsAdult" name="Print isAdult" scriptFormat="java">
      <bpmn2:script>
        System.out.println(">>> isAdult = " + kcontext.getVariable("isAdult"));
      </bpmn2:script>
    </bpmn2:scriptTask>

    <bpmn2:sequenceFlow id="flow_print" sourceRef="callSimpleRuleProcess" targetRef="printIsAdult"/>
    <bpmn2:sequenceFlow id="flow_end" sourceRef="printIsAdult" targetRef="end"/>

    <bpmn2:endEvent id="end"/>

    <bpmn2:sequenceFlow id="flow1" sourceRef="start" targetRef="script1"/>
    <bpmn2:sequenceFlow id="flow2" sourceRef="script1" targetRef="gateway1"/>

    <bpmn2:sequenceFlow id="flow_underage" sourceRef="gateway1" targetRef="underageTask">
      <bpmn2:conditionExpression xsi:type="bpmn2:tFormalExpression" language="http://www.java.com/java">
        return ((Integer)kcontext.getVariable("age")) &lt; 18;
      </bpmn2:conditionExpression>
    </bpmn2:sequenceFlow>

    <bpmn2:sequenceFlow id="flow_adult" sourceRef="gateway1" targetRef="adultTask">
      <bpmn2:conditionExpression xsi:type="bpmn2:tFormalExpression" language="http://www.java.com/java">
        return ((Integer)kcontext.getVariable("age")) >= 18;
      </bpmn2:conditionExpression>
    </bpmn2:sequenceFlow>

    <bpmn2:sequenceFlow id="flow_merge1" sourceRef="underageTask" targetRef="gateway2"/>
    <bpmn2:sequenceFlow id="flow_merge2" sourceRef="adultTask" targetRef="gateway2"/>

    <bpmn2:sequenceFlow id="flow_to_call" sourceRef="gateway2" targetRef="callSimpleRuleProcess"/>

  </bpmn2:process>

  <bpmndi:BPMNDiagram id="Diagram-demo">
    <bpmndi:BPMNPlane id="Plane-demo" bpmnElement="demo.process">

      <bpmndi:BPMNShape id="shape_start" bpmnElement="start">
        <dc:Bounds x="80" y="120" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="shape_script1" bpmnElement="script1">
        <dc:Bounds x="180" y="110" width="140" height="60"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="shape_gateway1" bpmnElement="gateway1">
        <dc:Bounds x="350" y="120" width="50" height="50"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="shape_underage" bpmnElement="underageTask">
        <dc:Bounds x="450" y="40" width="170" height="60"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="shape_adult" bpmnElement="adultTask">
        <dc:Bounds x="450" y="200" width="170" height="60"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="shape_gateway2" bpmnElement="gateway2">
        <dc:Bounds x="660" y="120" width="50" height="50"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="shape_callSimpleRuleProcess" bpmnElement="callSimpleRuleProcess">
        <dc:Bounds x="780" y="110" width="180" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="shape_end" bpmnElement="end">
        <dc:Bounds x="1000" y="130" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="edge_flow1" bpmnElement="flow1">
        <di:waypoint x="116" y="138"/>
        <di:waypoint x="180" y="140"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="edge_flow2" bpmnElement="flow2">
        <di:waypoint x="320" y="140"/>
        <di:waypoint x="350" y="145"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="edge_underage" bpmnElement="flow_underage">
        <di:waypoint x="400" y="145"/>
        <di:waypoint x="450" y="70"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="edge_adult" bpmnElement="flow_adult">
        <di:waypoint x="400" y="145"/>
        <di:waypoint x="450" y="230"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="edge_merge1" bpmnElement="flow_merge1">
        <di:waypoint x="620" y="70"/>
        <di:waypoint x="660" y="145"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="edge_merge2" bpmnElement="flow_merge2">
        <di:waypoint x="620" y="230"/>
        <di:waypoint x="660" y="145"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="edge_to_call" bpmnElement="flow_to_call">
        <di:waypoint x="710" y="145"/>
        <di:waypoint x="780" y="150"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="edge_to_end" bpmnElement="flow_to_end">
        <di:waypoint x="960" y="150"/>
        <di:waypoint x="1000" y="148"/>
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</bpmn2:definitions>