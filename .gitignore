################################################################################
# GLOBAL SETTINGS FOR JAVA / MAVEN / SPRING BOOT / INTELLIJ PROJECTS
################################################################################

# Maven build output
target/
**/target/

# Maven wrapper
.mvn/wrapper/maven-wrapper.jar
.mvn/wrapper/maven-wrapper.properties

# Spring Boot Fat JARs
*.jar
*.war
*.original
*.tmp

################################################################################
# IntelliJ IDEA / JetBrains
################################################################################

# Project settings
.idea/
.idea/**

# IntelliJ module / workspace files
*.iml
*.iws
*.ipr

# IntelliJ caches
.idea/**/workspace.xml
.idea/**/tasks.xml
.idea/**/dictionaries
.idea/**/shelf/
.idea/**/httpRequests

# JetBrains plugins artifacts
.idea/**/aws.xml
.idea/**/dbnavigator.xml
.idea/**/sonarlint/

################################################################################
